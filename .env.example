# ─── Base de datos ───────────────────────────────────────────────
# Para desarrollo local: docker compose up -d db
DATABASE_URL="postgresql://saldare:saldare123@localhost:5432/saldare"

# ─── Servidor ────────────────────────────────────────────────────
PORT=3001

# ─── Autenticación ───────────────────────────────────────────────
# Token para bypassear Firebase Auth en desarrollo
AUTH_BYPASS_TOKEN="dev-token"

# ─── Google Cloud ────────────────────────────────────────────────
# ID del proyecto GCP/Firebase. Cloud Run lo inyecta automáticamente;
# necesario solo en desarrollo local.
GOOGLE_CLOUD_PROJECT=""
# Ruta al archivo JSON de cuenta de servicio (usa «gcloud auth application-default login» o
# asigna la variable a un JSON path). Necesario para Document AI y Firebase Admin SDK.
GOOGLE_APPLICATION_CREDENTIALS=""

# ─── Document AI ─────────────────────────────────────────────────
DOCUMENT_AI_PROJECT_ID=""
DOCUMENT_AI_PROCESSOR_ID=""
DOCUMENT_AI_PROCESSOR_LOCATION="us"

# ─── Subida de archivos ──────────────────────────────────────────
UPLOAD_DIR="/tmp/uploads"
MAX_FILE_SIZE="5242880"
